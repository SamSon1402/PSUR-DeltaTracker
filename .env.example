# API
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Signal detection threshold
# Standard PV threshold: lower 95% CI of ROR > 1.0
SIGNAL_ROR_LOWER_CI_THRESHOLD=1.0

# Minimum case count for ROR calculation to be considered (avoid tiny-N false signals)
SIGNAL_MIN_CASES=3
